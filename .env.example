# X (Twitter) API Credentials
# Get these from https://developer.x.com/en/portal/dashboard

# OAuth 1.0a (required for write operations: posting, liking, retweeting)
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# OAuth 2.0 Bearer Token (used for read operations: search, lookup)
X_BEARER_TOKEN=your_bearer_token_here

# OAuth 2.0 token cache for bookmark tools.
# macOS defaults to Keychain. File storage is a fallback and must be explicit.
# X_MCP_TOKEN_STORE=keychain
# X_MCP_TOKEN_STORE=file
# X_MCP_ALLOW_FILE_TOKEN_STORE=true
